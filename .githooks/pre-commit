#!/usr/bin/env bash
set -euo pipefail

# Simple pre-commit hook: run tests if package.json has a test script
ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

if [ -f package.json ]; then
  has_test=$(node -e "const p=require('./package.json'); console.log(!!p.scripts && !!p.scripts.test)") || true
  if [ "$has_test" = "true" ]; then
    echo "Running npm test before commit..."
    npm test || { echo "Tests failed — aborting commit"; exit 1; }
  else
    echo "No npm test script — skipping tests"
  fi
else
  echo "No package.json — skipping tests"
fi

exit 0
